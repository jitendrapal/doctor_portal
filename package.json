{
  "name": "medconnect-ai",
  "private": true,
  "version": "1.0.0",
  "description": "MedConnect AI monorepo",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "corepack pnpm -r --parallel dev",
    "dev:frontend": "corepack pnpm --filter @medconnect/frontend dev",
    "build": "corepack pnpm -r build",
    "build:frontend": "corepack pnpm --filter @medconnect/frontend build",
    "lint": "corepack pnpm -r lint",
    "test": "corepack pnpm -r test",
    "format": "corepack pnpm -r format",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.yml down"
  }
}
